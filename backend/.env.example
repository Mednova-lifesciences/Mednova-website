# Copy this file to .env and fill in your real key.
# Never commit the real .env file to version control.

ANTHROPIC_API_KEY=your_api_key_here
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@updates.mednovalife.com
CONSULTATION_EMAIL=info@mednovalife.com

# Optional — override the default model
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — override the default port
# PORT=3000
