{
  "version": 2,
  "builds": [
    { "src": "config.js", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/(.*)$", "dest": "/$1" }
  ]
}
