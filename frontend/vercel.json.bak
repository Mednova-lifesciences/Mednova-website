{
  "version": 2,
  "builds": [
    { "src": "config.js", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/robots\\.txt$", "dest": "/public/robots.txt" },
    { "src": "^/sitemap\\.xml$", "dest": "/public/sitemap.xml" },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/([^/]+\\.html)$", "dest": "/$1" },
    { "src": "^/(.*)$", "dest": "/$1" }
  ]
}
