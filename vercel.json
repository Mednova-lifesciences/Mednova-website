{
  "version": 2,
  "builds": [
    { "src": "frontend/index.html", "use": "@vercel/static" },
    { "src": "frontend/*.html", "use": "@vercel/static" },
    { "src": "frontend/**/*.html", "use": "@vercel/static" },
    { "src": "frontend/public/**", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests; block-all-mixed-content" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ],
  "routes": [
    { "src": "^/robots\\.txt$", "dest": "/public/robots.txt" },
    { "src": "^/sitemap\\.xml$", "dest": "/public/sitemap.xml" },
    { "src": "^/$", "dest": "/frontend/index.html" },
    { "src": "^/about/?$", "dest": "/frontend/about/index.html" },
    { "src": "^/contact/?$", "dest": "/frontend/contact/index.html" },
    { "src": "^/services/?$", "dest": "/frontend/services/index.html" },
    { "src": "^/capability-statement\\.html$", "dest": "/frontend/capability-statement.html" },
    { "src": "^/compliance-checklist\\.html$", "dest": "/frontend/compliance-checklist.html" },
    { "src": "^/cro\\.html$", "dest": "/frontend/cro.html" },
    { "src": "^/pv\\.html$", "dest": "/frontend/pv.html" },
    { "src": "^/regulatory\\.html$", "dest": "/frontend/regulatory.html" },
    { "src": "^/(.+)$", "dest": "/frontend/$1" }
  ]
}
